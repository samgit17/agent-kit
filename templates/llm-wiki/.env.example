# LLM provider — required
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o

# Optional: override to use any OpenAI-compatible endpoint
# Examples:
#   Ollama:  http://localhost:11434/v1
#   vLLM:    http://localhost:8000/v1
# LLM_BASE_URL=

# Note: PDF and DOCX ingestion requires docling (pip install docling).
# Docling downloads AI models (~500MB) on first run.

# Optional: override default directories
# WIKI_DIR=wiki
# SOURCES_DIR=sources
# SOURCES_DIR=sources

# Optional: max ReAct loop iterations per operation (default: 10)
# WIKI_MAX_ITERATIONS=10
