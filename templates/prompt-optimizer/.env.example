# LLM provider: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Ollama (default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:35b-a3b   # proposer — needs strong instruction following

# EVAL_MODEL — used by eval.py for output generation and scoring.
# Set to a smaller/faster model than OLLAMA_MODEL to speed up eval runs.
# Falls back to OLLAMA_MODEL if not set.
EVAL_MODEL=phi4-mini:3.8b

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# EVAL_MODEL=gpt-4o-mini      # or gpt-3.5-turbo for faster eval

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# EVAL_MODEL=claude-haiku-4-5-20251001  # fast eval scoring
