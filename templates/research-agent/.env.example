# ============================================================
# Research Agent — Environment Variables
# Copy to .env and fill in. Never commit .env.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Choose: openai | ollama
LLM_PROVIDER=openai

# ── OpenAI (if LLM_PROVIDER=openai) ─────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Ollama (if LLM_PROVIDER=ollama) ──────────────────────────
# Requires a running Ollama instance.
# Recommended models for reliable JSON output (no thinking mode):
#   gpt-oss:20b       — fast, good JSON, no thinking mode
#   mistral:latest    — reliable, lightweight
#   llama3.1:8b       — good default if above not available
# Avoid thinking models (qwen3.5, deepseek-r1) — they conflict with JSON parsing.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b

# ── Search Provider ───────────────────────────────────────────
# Choose: tavily | duckduckgo
# Tavily gives better structured results. DuckDuckGo is free, no key needed.
SEARCH_PROVIDER=tavily

# ── Tavily (if SEARCH_PROVIDER=tavily) ───────────────────────
# Get a free key at: https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Pipeline Tuning ───────────────────────────────────────────
MAX_SEARCH_QUERIES=5       # max queries the planner will generate
MAX_SEARCH_RESULTS=3       # results per query
MAX_CONTENT_CHARS=400      # chars per search result sent to LLM — keep low to fit context window
VERIFIER_THRESHOLD=0.70    # min confidence score to accept answer (0.0–1.0)
OLLAMA_TIMEOUT=180         # seconds before Ollama call times out
OLLAMA_MAX_TOKENS=4096     # max tokens per Ollama call — 2048 truncates synthesiser answers
ENABLE_RETRY=false         # set true to re-synthesise on low confidence (doubles latency on local models)
