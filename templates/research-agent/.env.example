# ============================================================
# Research Agent — Environment Variables
# Copy to .env and fill in. Never commit .env.
# ============================================================

# ── LLM Provider ─────────────────────────────────────────────
# Choose: openai | ollama
LLM_PROVIDER=openai

# ── OpenAI (if LLM_PROVIDER=openai) ─────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Ollama (if LLM_PROVIDER=ollama) ──────────────────────────
# Requires a running Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Search Provider ───────────────────────────────────────────
# Choose: tavily | duckduckgo
# Tavily gives better structured results. DuckDuckGo is free, no key needed.
SEARCH_PROVIDER=tavily

# ── Tavily (if SEARCH_PROVIDER=tavily) ───────────────────────
# Get a free key at: https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Pipeline Tuning ───────────────────────────────────────────
MAX_SEARCH_QUERIES=5       # max queries the planner will generate
MAX_SEARCH_RESULTS=3       # results per query
VERIFIER_THRESHOLD=0.70    # min confidence score to accept answer (0.0–1.0)
